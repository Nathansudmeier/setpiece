NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Alleen server-side. Nodig voor contactopslag en de gedeelde rate limiter.
# Gebruik de nieuwe Supabase secret key, nooit een NEXT_PUBLIC_-variabele.
SUPABASE_SECRET_KEY=

# Optioneel apart HMAC-geheim voor geanonimiseerde rate-limit identifiers.
# Zonder deze waarde wordt SUPABASE_SECRET_KEY gebruikt.
RATE_LIMIT_SECRET=

# Server-side sleutel voor de AI-intake (/api/intake). Niet met NEXT_PUBLIC_,
# blijft geheim op de server. Zet dezelfde waarde in Vercel (Project Settings
# > Environment Variables) zodat de intake ook live werkt.
ANTHROPIC_API_KEY=
ANTHROPIC_INTAKE_MODEL=claude-haiku-4-5
ANTHROPIC_INTAKE_FALLBACK_MODEL=claude-sonnet-5
INTAKE_DAILY_LIMIT=80

# Cloudflare Turnstile. De site key mag publiek zijn; de secret key nooit.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
